# Frontend Supabase config. These values are exposed to the browser by Vite.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
DATABASE_URL=

# Supabase Edge Function secrets for supabase/functions/send-sms.
# Do not expose these through VITE_* variables.
TEXTLK_API_TOKEN=
TEXTLK_SENDER_ID=


